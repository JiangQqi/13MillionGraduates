  ActiveTalk:
  - "\u8BFE\u95F4\u64CD\u65F6\u95F4\uFF01\\n\u8FD9\u662F\u5EA7\u4F4D\u8868\uFF0C\u4F60\u6765\u7EC4\u7EC7\u961F\u4F0D\u3002"
  - "\u7537\u751F\u5148\u51FA\u53BB\uFF0C\\n\u5973\u751F\u540E\u51FA\u53BB\u3002"
  - "\u540D\u5355\u7684\u672B\u5C3E\u4E3A\u4EC0\u4E48\\n\u6709\u4E00\u4E2A\u300C0\u300D\uFF1F"
  - "\u6211\u4E5F\u4E0D\u77E5\u9053\uFF0C\\n\u6216\u8BB8\u662F\u6559\u52A1\u5904\u7684\u7EB0\u6F0F\u3002"
  MoreTalk:
  - "\u6709\u65F6\u5019\u540D\u5355\u4E0A\u7684\u4EBA\u6570\uFF0C\\n\u5E76\u4E0D\u4F1A\u521A\u597D\u914D\u5BF9\u3002"
  - "\u8FD9\u79CD\u60C5\u51B5\u5728\u6559\u80B2\u5B66\u4E0A\uFF0C\\n\u88AB\u79F0\u4E3A\u2014\u2014"
  - "\u5443\u3002"
  - "\u5176\u5B9E\u6211\u4E5F\u4E0D\u77E5\u9053\u53EB\u4EC0\u4E48\u3002\\n\u4F46\u542C\u8D77\u6765\u5C31\u5F88\u590D\u6742\u3002"
  - "\u65E2\u7136\u5F88\u590D\u6742\uFF0C"
  - "\u90A3\u5C31\u4EA4\u7ED9\u5168\u5E74\u7EA7\u6700\u4F18\u79C0\u7684\u65B0\u751F\u5427\u3002"
  ExampleTalk:
  - "\u5982\u679C\u4F60\u7684INBOX(\u8F93\u5165\u680F)\u91CC\u6709:\n\u90D1 \u738B
