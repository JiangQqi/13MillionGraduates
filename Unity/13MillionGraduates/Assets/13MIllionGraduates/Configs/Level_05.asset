  ActiveTalk:
  - "\u671F\u4E2D\u8003\u8BD5\u7ED3\u675F\u4E86\uFF01"
  - "\u7EC8\u4E8E\u5230\u4E86\\n\u516C\u5E03\u6392\u540D\u7684\u65F6\u5019\u3002"
  - "\u5B66\u6821\u4E00\u76F4\u9F13\u52B1\u540C\u5B66\u4EEC\\n\u5171\u540C\u8FDB\u6B65\u3002"
